generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username            String?   @unique
  email               String?   @unique
  emailVerified       DateTime?
  phone               String?   @unique
  password            String?
  name                String?
  image               String?
  onboardingCompleted Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  accounts              Account[]
  sessions              Session[]
  sports                UserSport[]
  products              Product[]
  chatAsBuyer           Chat[]    @relation("ChatBuyer")
  chatAsSeller          Chat[]    @relation("ChatSeller")
  messagesSent          Message[] @relation("MessageSender")
  ordersAsBuyer         Order[]   @relation("OrderBuyer")
  ordersAsSeller        Order[]   @relation("OrderSeller")
  pushSubscriptions     PushSubscription[]
  notificationSettings  NotificationSettings?
  shippingAddresses     ShippingAddress[]
  bankAccounts          BankAccount[]
  paymentMethods        PaymentMethod[]
  wishlists             Wishlist[]
  cartItems             CartItem[]
}

model ShippingAddress {
  id            String   @id @default(cuid())
  userId        String
  label         String   // 집, 회사, 기타
  recipient     String
  phone         String
  zipCode       String
  address       String
  addressDetail String?
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BankAccount {
  id            String   @id @default(cuid())
  userId        String
  bankName      String
  accountNumber String
  accountHolder String
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PaymentMethod {
  id          String   @id @default(cuid())
  userId      String
  type        String   // kakao | toss | naver | card
  alias       String
  billingKey  String?  // Toss 빌링키 or KakaoPay SID
  customerKey String?  // Toss customerKey
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NotificationSettings {
  id          String  @id @default(cuid())
  userId      String  @unique
  chat        Boolean @default(true)
  transaction Boolean @default(true)
  wishlist    Boolean @default(true)
  newProduct  Boolean @default(false)
  marketing   Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSport {
  id     String @id @default(cuid())
  userId String
  sport  String // soccer, basketball 등
  level  String // beginner, amateur, pro

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sport])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SearchLog {
  id        String   @id @default(cuid())
  query     String
  createdAt DateTime @default(now())
}

model SportClickLog {
  id        String   @id @default(cuid())
  sport     String   // soccer, baseball 등
  createdAt DateTime @default(now())
}

model Product {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  price       Int
  sport       String   // soccer, basketball 등
  productType String?  // 용품 종류 탭 ID: shoes, ball, uniform, glove, bat 등
  metadata    String?  // JSON: 종목별 상세 정보 (brand, model, sizeMM, studType 등)
  level       String?  // beginner, amateur, pro — null이면 모든 레벨 대상
  grade       String?  // S, A, B, C, F (AI 진단 등급)
  score       Int?
  discount    Int?
  location    String?
  images      String   @default("[]") // JSON 배열 (Cloudinary URL)
  status      String   @default("active") // active, sold, hidden
  likes       Int      @default(0)
  allowOffer  Boolean  @default(true)   // 가격 제안 허용 여부
  shippingType String? // included | separate
  shippingFeeType String? // prepaid | cod (shippingType=separate 일 때)
  shippingFee  Int?    // 배송비 금액
  allowMeetup Boolean  @default(true)   // 직거래 허용 여부
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  chats     Chat[]
  orders    Order[]
  wishlists Wishlist[]
  cartItems CartItem[]
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Chat {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  productId String
  buyerId   String
  sellerId  String

  product  Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  buyer    User      @relation("ChatBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  seller   User      @relation("ChatSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  messages Message[]
  order    Order?

  @@unique([productId, buyerId])
}

model Message {
  id        String   @id @default(cuid())
  content   String
  type      String   @default("text") // text | system_payment | system_preparing | system_shipped
  metadata  String?  // JSON: 시스템 메시지 부가 데이터
  createdAt DateTime @default(now())
  chatId    String
  senderId  String?  // 시스템 메시지는 null

  chat   Chat  @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender User? @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
}

model Order {
  id              String    @id @default(cuid())
  chatId          String    @unique
  productId       String
  buyerId         String
  sellerId        String
  status          String    @default("paid") // paid | preparing | shipped | delivered | cancelled
  shippingMethod  String?
  buyerNote       String?
  trackingNumber  String?
  trackingCarrier String?
  refundDeadline  DateTime?
  shippingSnapshot String?   // JSON: 주문 시점 배송지 스냅샷
  paidAt          DateTime  @default(now())
  preparingAt     DateTime?
  shippedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  chat    Chat    @relation(fields: [chatId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  buyer   User    @relation("OrderBuyer", fields: [buyerId], references: [id])
  seller  User    @relation("OrderSeller", fields: [sellerId], references: [id])
}
