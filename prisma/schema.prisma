generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                @id @default(cuid())
  username             String?               @unique
  email                String?               @unique
  emailVerified        DateTime?
  phone                String?               @unique
  password             String?
  name                 String?
  image                String?
  onboardingCompleted  Boolean               @default(false)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  accounts             Account[]
  bankAccounts         BankAccount[]
  cartItems            CartItem[]
  chatAsBuyer          Chat[]                @relation("ChatBuyer")
  chatAsSeller         Chat[]                @relation("ChatSeller")
  messagesSent         Message[]             @relation("MessageSender")
  notificationSettings NotificationSettings?
  ordersAsBuyer        Order[]               @relation("OrderBuyer")
  ordersAsSeller       Order[]               @relation("OrderSeller")
  paymentMethods       PaymentMethod[]
  products             Product[]
  pushSubscriptions    PushSubscription[]
  sessions             Session[]
  shippingAddresses    ShippingAddress[]
  sports               UserSport[]
  wishlists            Wishlist[]
}

model ShippingAddress {
  id            String   @id @default(cuid())
  userId        String
  label         String
  recipient     String
  phone         String
  zipCode       String
  address       String
  addressDetail String?
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BankAccount {
  id            String   @id @default(cuid())
  userId        String
  bankName      String
  accountNumber String
  accountHolder String
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PaymentMethod {
  id          String   @id @default(cuid())
  userId      String
  type        String
  alias       String
  billingKey  String?
  customerKey String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NotificationSettings {
  id          String  @id @default(cuid())
  userId      String  @unique
  chat        Boolean @default(true)
  transaction Boolean @default(true)
  wishlist    Boolean @default(true)
  newProduct  Boolean @default(false)
  marketing   Boolean @default(false)
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSport {
  id     String @id @default(cuid())
  userId String
  sport  String
  level  String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sport])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SearchLog {
  id        String   @id @default(cuid())
  query     String
  createdAt DateTime @default(now())
}

model SportClickLog {
  id        String   @id @default(cuid())
  sport     String
  createdAt DateTime @default(now())
}

model Product {
  id              String     @id @default(cuid())
  userId          String
  name            String
  description     String?
  price           Int
  sport           String
  productType     String?
  metadata        String?
  level           String?
  grade           String?
  score           Int?
  discount        Int?
  location        String?
  images          String     @default("[]")
  status          String     @default("active")
  likes           Int        @default(0)
  allowOffer      Boolean    @default(true)
  shippingType    String?
  shippingFeeType String?
  shippingFee     Int?
  allowMeetup     Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  cartItems       CartItem[]
  chats           Chat[]
  orders          Order[]
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  wishlists       Wishlist[]
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Chat {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  productId String
  buyerId   String
  sellerId  String
  buyer     User      @relation("ChatBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  seller    User      @relation("ChatSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  messages  Message[]
  order     Order?

  @@unique([productId, buyerId])
}

model Message {
  id        String   @id @default(cuid())
  content   String
  type      String   @default("text")
  metadata  String?
  createdAt DateTime @default(now())
  chatId    String
  senderId  String?
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender    User?    @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
}

model Order {
  id               String    @id @default(cuid())
  chatId           String    @unique
  productId        String
  buyerId          String
  sellerId         String
  status           String    @default("paid")
  shippingMethod   String?
  buyerNote        String?
  trackingNumber   String?
  trackingCarrier  String?
  refundDeadline   DateTime?
  shippingSnapshot String?
  paidAt           DateTime  @default(now())
  preparingAt      DateTime?
  shippedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  buyer            User      @relation("OrderBuyer", fields: [buyerId], references: [id])
  chat             Chat      @relation(fields: [chatId], references: [id], onDelete: Cascade)
  product          Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  seller           User      @relation("OrderSeller", fields: [sellerId], references: [id])
}
